---
import Layout from "../layouts/Layout.astro";

const slides = [
  {
    color: "#7c6aff",
    emoji: "🚀",
    title: "CSS Scroll Snap",
    desc: "スクロールを特定位置に吸着させるCSS仕様",
  },
  {
    color: "#06b6d4",
    emoji: "🎯",
    title: ":target セレクタ",
    desc: "URLハッシュと一致する要素にスタイルを適用",
  },
  {
    color: "#f59e0b",
    emoji: "✨",
    title: "Scroll-driven Animations",
    desc: "スクロール位置に連動したアニメーション",
  },
  {
    color: "#10b981",
    emoji: "🎨",
    title: "@starting-style",
    desc: "要素が表示された瞬間のアニメーション初期値を定義",
  },
];
---

<Layout title="Carousel UI" description="モダンCSSだけで作るカルーセルUIの比較">
  <a href="/" class="back">← 一覧へ</a>
  <h1 class="page-title">Carousel UI</h1>
  <p class="page-subtitle">JSなし・モダンCSSだけで作る2つのアプローチを比較</p>

  <!-- ========== Approach 1: ::scroll-button + ::scroll-marker ========== -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">
        Approach 1 — <code>::scroll-button()</code> + <code
          >::scroll-marker</code
        >
      </h2>
      <span class="badge badge--red">Chrome 135+</span>
    </div>
    <p class="section-desc">
      CSS Overflow 5 の新機能。<code>::scroll-button()</code> 疑似要素で前後ボタンを、
      <code>::scroll-marker</code> でドットインジケーターをCSSだけで生成。 HTML は
      <code>&lt;ul&gt;&lt;li&gt;</code> のみでナビゲーション要素不要。 コンテナを
      CSS Grid にして <code>grid-area</code> でボタン・ドットの位置を制御する。
    </p>

    <!--
      コンテナを grid にして left / carousel / right / markers の4エリアを定義。
      ::scroll-button と ::scroll-marker-group が grid-area で各エリアに配置される。
    -->
    <div class="c1-container">
      <ul class="carousel-1">
        {
          slides.map((s) => (
            <li class="c1-slide" style={`--slide-color: ${s.color}`}>
              <span class="slide-emoji">{s.emoji}</span>
              <h3 class="slide-title">{s.title}</h3>
              <p class="slide-desc">{s.desc}</p>
            </li>
          ))
        }
      </ul>
    </div>

    <p class="support-note">
      ※ このカルーセルはChrome 135以上でお試しください。
      それ以外のブラウザでは前後ボタンとドットが表示されません。
    </p>
  </section>
</Layout>

<style>
  .support-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
  }

  /* ---- 共通スライドカード ---- */
  .slide-emoji {
    font-size: 2.5rem;
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }
  .slide-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--slide-color);
  }
  .slide-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* =============================================
     Approach 1: ::scroll-button + ::scroll-marker
     =============================================
     コンテナを grid にして
       left     | carousel | right
       ......   | markers  | ......
     の2行3列レイアウトを定義する。
     ::scroll-button と ::scroll-marker-group が
     grid-area で各セルに収まる。
  */
  .c1-container {
    display: grid;
    grid-template-areas:
      "left  carousel  right"
      "...   markers   ...";
    grid-template-columns: auto 1fr auto;
    row-gap: 0.75rem;
    align-items: center;
  }

  .carousel-1 {
    grid-area: carousel;
    list-style: none;
    padding: 0;
    margin: 0;

    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-snap-stop: always;
    scroll-behavior: smooth;
    scrollbar-width: none;

    /* ::scroll-marker-group をカルーセルの後ろに配置 */
    scroll-marker-group: after;

    border-radius: var(--radius);

    /* 前後ボタン */
    &::scroll-button(*) {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.4rem;
      height: 2.4rem;
      border-radius: 50%;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-text);
      font-size: 1.2rem;
      cursor: pointer;
      transition:
        border-color 0.15s,
        background 0.15s;
    }

    &::scroll-button(*):not(:disabled):hover {
      border-color: var(--color-accent);
      background: color-mix(
        in srgb,
        var(--color-accent) 10%,
        var(--color-surface)
      );
    }

    &::scroll-button(*):disabled {
      opacity: 0.25;
      cursor: default;
    }

    &::scroll-button(left) {
      content: "‹" / "前へ";
      grid-area: left;
      justify-self: end;
    }

    &::scroll-button(right) {
      content: "›" / "次へ";
      grid-area: right;
    }

    /* ドットグループ */
    &::scroll-marker-group {
      grid-area: markers;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
    }
  }

  .c1-slide {
    flex: 0 0 91%;
    scroll-snap-align: center;
    padding: 2.5rem 2rem;
    background: color-mix(in srgb, var(--slide-color) 10%, var(--color-bg));
    border: 1px solid color-mix(in srgb, var(--slide-color) 30%, transparent);
    border-radius: var(--radius);
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;

    /* ドット本体 */
    &::scroll-marker {
      content: "";
      display: block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--color-border);
      transition:
        background 0.2s,
        scale 0.2s;
    }

    &::scroll-marker:target-current {
      background: var(--color-accent);
      scale: 1.4;
    }
  }
</style>
